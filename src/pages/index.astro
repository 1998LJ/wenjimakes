---
import Layout from '../layouts/Layout.astro';
import ModCard from '../components/ModCard.astro';

const featured = {
  nexusId: 'ginger-island-survival',
  title: 'Ginger Island Survival',
  description: '开局不在农场——你醒在姜岛岸边，一无所有。探索、求生、一步步挣回大陆。大型玩法 Mod，含海盗打劫等原创剧情。',
  image: 'https://staticdelivery.nexusmods.com/mods/1303/images/thumbnails/46543/46543-1779461586-506636996.jpg',
  tags: ['大改', '剧情', '生存'],
};

const mods = [
  {
    nexusId: 'fishing-net',
    title: 'Fishing Net',
    description: '巨型渔网，放水里过夜自动捕鱼。耐用度逐渐下降，记得及时收取。',
    image: 'https://staticdelivery.nexusmods.com/mods/1303/images/thumbnails/47586/47586-1781331081-162269952.jpg',
    tags: ['工具', '捕鱼'],
  },
  {
    nexusId: 'universal-tool',
    title: 'Universal Tool — Extraterrestrial Meteor Ruler',
    description: '故意超模的全能工具：砸、砍、收割、终结木乃伊、还能召唤旋转剑阵。',
    image: 'https://staticdelivery.nexusmods.com/mods/1303/images/thumbnails/48087/48087-1782230097-2143305005.png',
    tags: ['武器', '工具', '超模'],
  },
];
---
<Layout title="文几 Makes — 星露谷 Mod 创作者" description="文几——星露谷物语 Mod 创作者。Ginger Island Survival、Fishing Net、Universal Tool 等原创 mod。">
  <section class="hero">
    <div class="container">
      <h1>做自己<em>想玩</em>的东西</h1>
      <p class="hero-sub">我是文几，给星露谷做 Mod。游戏里没有的玩法，我自己做出来。</p>
      <div class="hero-actions">
        <a href="/mods" class="btn btn-primary">看看作品</a>
        <a href="https://ko-fi.com/wenjimods" target="_blank" class="btn btn-outline">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/></svg>
          请喝咖啡
        </a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="section-label">已发布 · Nexus Mods</p>

      <a href={`/mods/${featured.nexusId}`} class="featured-mod">
        <img class="featured-mod-image" src={featured.image} alt={featured.title} loading="eager" fetchpriority="high" />
        <div class="featured-mod-body">
          <div class="mod-tags">
            {featured.tags.map(tag => <span class="tag">{tag}</span>)}
          </div>
          <h3>{featured.title}</h3>
          <p>{featured.description}</p>
          <span class="mod-link">查看详情 →</span>
        </div>
      </a>

      <div class="mod-grid homepage-mod-grid">
        {mods.map(m => (
          <ModCard
            nexusId={m.nexusId}
            title={m.title}
            description={m.description}
            image={m.image}
            tags={m.tags}
          />
        ))}
      </div>

      <div class="wip-strip homepage-wip-strip">
        <span class="wip-strip-icon">🎵</span>
        <div class="wip-strip-text">
          <h4>魔笛 Mod <span class="tag tag-wip">制作中</span></h4>
          <p>音乐施法玩法，正在开发。</p>
        </div>
      </div>
    </div>
  </section>

  <section class="bottom-bar">
    <div class="container">
      <div class="bottom-bar-inner">
        <div class="bottom-bar-item">
          <p><strong>想定制 Mod？</strong> 有想法我帮你实现。</p>
          <a href="/services" class="btn btn-ghost">了解详情 →</a>
        </div>
        <span class="bottom-divider"></span>
        <div class="bottom-bar-item">
          <p>喜欢这些 Mod？</p>
          <a href="https://ko-fi.com/wenjimods" target="_blank" class="kofi-btn">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/></svg>
            Ko-fi 支持
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
